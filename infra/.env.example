# Copia este archivo a .env y cambia los valores.   cp .env.example .env

# Contraseña de PostgreSQL (interna).
POSTGRES_PASSWORD=cambia-esta-clave-postgres

# Secreto para firmar los JWT. Debe tener al menos 32 caracteres.
JWT_SECRET=cambia-esta-clave-jwt-larga-de-al-menos-32-caracteres-2026

# Dirección del sitio (Caddy):
#   :80                        -> solo HTTP, accede con la IP pública de la VM.
#   reciclape.duckdns.org      -> HTTPS automático con ese dominio.
SITE_ADDRESS=:80
